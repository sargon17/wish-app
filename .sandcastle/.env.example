# Optional: GitHub token used by gh inside Sandcastle sandboxes.
# The package scripts export GH_TOKEN from `gh auth token` when GH_TOKEN is not
# already set. Run on the host first if needed:
#   gh auth login
GH_TOKEN=

# Codex auth is shared by mounting ~/.codex-sandcastle into the sandbox.
# Recommended setup keeps sandbox Codex config minimal and avoids host MCP/plugin config:
#   mkdir -p ~/.codex-sandcastle
#   cp ~/.codex/auth.json ~/.codex-sandcastle/auth.json
#   cat > ~/.codex-sandcastle/config.toml <<'EOF'
#   model = "gpt-5.4-mini"
#   model_reasoning_effort = "low"
#   sandbox_mode = "danger-full-access"
#
#   [projects."/home/agent/workspace"]
#   trust_level = "trusted"
#   EOF
# Run on the host first if auth is missing:
#   codex login
