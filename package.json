{
  "name": "wish-app",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "vp run -r build",
    "check": "vp run -r check",
    "check-types": "vp run -r check-types",
    "convex:dev": "vp run -r convex:dev",
    "dev": "vp run wish-start#dev",
    "dev:all": "vp run -r dev",
    "dev:doc": "vp run wish-app-docs#dev",
    "format": "vp run -r fmt",
    "lint": "vp run -r lint",
    "test": "vp run -r test"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vite-plus": "^0.1.12"
  },
  "dependencies": {
    "type-fest": "^5.4.4"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest",
    "esbuild": "0.27.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  },
  "packageManager": "pnpm@10.32.1"
}
