{
  "name": "wish-app",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "vp run -r build",
    "check": "vp run -r check",
    "check-types": "vp run -r check-types",
    "convex:dev": "vp run -r convex:dev",
    "dev": "vp run wish-start#dev",
    "dev:all": "vp run -r dev",
    "format": "vp run -r fmt",
    "lint": "vp run -r lint",
    "sandcastle": "bash -lc 'export GH_TOKEN=${GH_TOKEN:-$(gh auth token)}; bun .sandcastle/main.mts'",
    "sandcastle:build-image": "docker build -t sandcastle:wish-app .sandcastle",
    "sandcastle:lead-delivery": "bash -lc 'export GH_TOKEN=${GH_TOKEN:-$(gh auth token)}; bun .sandcastle/lead-delivery/main.mts'",
    "test": "vp run -r test"
  },
  "devDependencies": {
    "@ai-hero/sandcastle": "^0.5.10",
    "@types/node": "^22.19.15",
    "@vercel/nft": "1.3.2",
    "croner": "^10.0.1",
    "get-port-please": "3.2.0",
    "perfect-debounce": "2.1.0",
    "rendu": "0.0.7",
    "scule": "^1.3.0",
    "typescript": "^5.9.3",
    "unctx": "2.5.0",
    "vite-plus": "^0.1.12",
    "vp": "1.0.3",
    "youch": "4.1.0",
    "youch-core": "0.3.3"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.12",
    "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.12",
    "esbuild": "0.27.1"
  },
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
