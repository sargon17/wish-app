{
	"extends": "astro/tsconfigs/strict",
	"compilerOptions": {
		"baseUrl": ".",
		"paths": {
			"@astrojs/starlight/loaders": ["./src/stubs/starlight-loaders.d.ts"],
			"@astrojs/starlight/schema": ["./src/stubs/starlight-schema.d.ts"]
		},
		"types": ["node"],
		"noImplicitAny": false,
		"skipLibCheck": true
	},
	"include": [".astro/types.d.ts", "**/*"],
	"exclude": ["dist"]
}
